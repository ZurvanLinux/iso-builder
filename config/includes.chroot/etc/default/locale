# Zurvan Linux default system locale (ui-ux-localization-plan.md §5).
# fa_IR.UTF-8 drives RTL mirroring AND the Jalali (Solar Hijri) calendar in the
# Plasma clock applet (Qt/ICU's fa_IR locale uses the Persian calendar).
# The locale itself is generated by config/hooks/normal/zurvan-locale.hook.chroot.
LANG=fa_IR.UTF-8
