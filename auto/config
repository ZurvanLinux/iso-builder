#!/bin/sh
# auto/config — live-build configuration entry point for Zurvan Linux.
#
# M1.1b scope: full spec-compliant KDE Plasma baseline on Debian Stable.
# contrib/non-free/non-free-firmware enabled per technical-spec-architecture.md
# §2.2 (firmware-iwlwifi/-realtek/-atheros live in non-free-firmware).
#
# The build pins the Debian *codename* (trixie, the current stable) rather than
# the rolling `stable` suite, for reproducibility and a stable security-suite
# path (trixie-security). When Debian releases a new stable, bump this codename
# + the container image; see the "Bump runbook" section in README.md.

set -e

lb config noauto \
    --distribution trixie \
    --architecture amd64 \
    --archive-areas "main contrib non-free non-free-firmware" \
    --binary-images iso-hybrid \
    --debian-installer none \
    --mirror-bootstrap        "https://deb.debian.org/debian" \
    --mirror-binary           "https://deb.debian.org/debian" \
    --parent-mirror-bootstrap "https://deb.debian.org/debian" \
    --parent-mirror-binary    "https://deb.debian.org/debian" \
    --mirror-bootstrap-security "https://deb.debian.org/debian-security" \
    --mirror-binary-security "https://deb.debian.org/debian-security" \
    --parent-mirror-bootstrap-security "https://deb.debian.org/debian-security" \
    --parent-mirror-binary-security "https://deb.debian.org/debian-security" \
    --iso-application "Zurvan Linux" \
    --iso-publisher   "Zurvan Linux - https://zurvanlinux.org" \
    --iso-preparer    "Zurvan Linux live-build pipeline (iso-builder)" \
    --iso-volume      "ZURVAN_LIVE" \
    --grub-distributor "Zurvan" \
    "${@}"

