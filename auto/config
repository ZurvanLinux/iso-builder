#!/bin/sh
# auto/config — live-build configuration entry point for Zurvan Linux.
#
# M1.1a scope: minimal CLI proof build. Its only purpose is to prove that
# `lb build` runs successfully inside the privileged GitHub Actions container
# (loop-device + disk-pressure probe). No desktop, no custom config.
# contrib/non-free/non-free-firmware are intentionally NOT enabled here;
# they are added in M1.1b per technical-spec-architecture.md §2.2.

set -e

lb config noauto \
    --distribution trixie \
    --architecture amd64 \
    --archive-areas "main" \
    --binary-images iso-hybrid \
    --debian-installer none \
    --mirror-bootstrap        "http://deb.debian.org/debian/" \
    --mirror-binary           "http://deb.debian.org/debian/" \
    --parent-mirror-bootstrap "http://deb.debian.org/debian/" \
    --parent-mirror-binary    "http://deb.debian.org/debian/" \
    --iso-application "Zurvan Linux" \
    --iso-publisher   "Zurvan Linux - https://zurvanlinux.org" \
    --iso-preparer    "Zurvan Linux live-build pipeline (iso-builder)" \
    --iso-volume      "ZURVAN_MINIMAL" \
    "${@}"
