#!/bin/sh
set -e

case "$1" in
install|upgrade)
	for f in /etc/os-release /etc/lsb-release /etc/hostname /etc/issue /etc/issue.net; do
		dpkg-divert --divert "$f.distrib" --rename "$f" 2>/dev/null || true
	done
	;;
abort-upgrade)
	for f in /etc/os-release /etc/lsb-release /etc/hostname /etc/issue /etc/issue.net; do
		dpkg-divert --remove --rename "$f" >/dev/null 2>&1 || true
	done
	;;
*)
	echo "preinst called with unknown argument \`$1'" >&2
	exit 1
	;;
esac

exit 0
